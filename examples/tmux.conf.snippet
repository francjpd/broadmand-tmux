# broadmand-tmux — install snippet
# Drop into your ~/.config/tmux/tmux.conf

# 1. Install (TPM, recommended):
#    set -g @plugin 'tmux-plugins/tpm'
#    set -g @plugin 'francjpd/broadmand-tmux'
#    run '~/.tmux/plugins/tpm/tpm'
#
# 2. Or install manually:
#    git clone git@github.com:francjpd/broadmand-tmux.git \
#      ~/.tmux/plugins/broadmand-tmux

# ----- broadmand-tmux configuration -----

# Keybinds
set -g @broadcast-run-key       'd'
set -g @broadcast-cd-picker-key 'D'

# Picker backend: fd | zoxide | both
# fd requires `fd`, zoxide requires `zoxide`, both prefers zoxide then fd.
set -g @broadcast-picker-engine 'fd'

# Comma-separated list of pane commands to never touch
set -g @broadcast-excluded 'vim,vi,nvim,less,man,ssh,htop,top,mc,opencode,claude,aider,continue,qwen,qwen-cli,gemini,gemini-cli,openai,ollama,copilot,codeium,anthropic,chatgpt,chatgpt-cli,sgpt,aichat,pplx,perplexity'

# Throttle (ms) between send-keys operations per pane
set -g @broadcast-pane-delay '5'

# Load the plugin (TPM or manual install path)
if-shell -b '[ -d ~/.tmux/plugins/broadmand-tmux ]' {
  run-shell '~/.tmux/plugins/broadmand-tmux/broadmand.tmux'
}
